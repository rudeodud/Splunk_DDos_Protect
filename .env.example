PORT=3000
HOST=127.0.0.1

# Splunk HTTP Event Collector endpoint.
# Example: https://splunk.example.com:8088/services/collector/event
SPLUNK_HEC_URL=https://splunk.example.com:8088/services/collector/event
SPLUNK_HEC_TOKEN=dc8b1e29-9bc2-44b2-93fa-9556d4c3fbd4

SPLUNK_HEC_INDEX=main
SPLUNK_HEC_SOURCE=virtual-store
SPLUNK_HEC_SOURCETYPE=ddos:store:click


# Set to true only for lab environments with self-signed Splunk certificates.
SPLUNK_HEC_INSECURE=false
1