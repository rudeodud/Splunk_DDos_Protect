# Local .terraform directories
**/.terraform/*

# .tfstate files
*.tfstate
*.tfstate.*
.terraform.tfstate.lock.info

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files, which are likely to contain sensitive data
*.tfvars
*.tfvars.json

# Ignore override files
*_override.tf
*_override.tf.json

# Ignore CLI configuration files
.terraformrc
terraform.rc

# Ignore tfplan
*tfplan*
*.tfplan
*.tfplan.json
*.plan

# Python cache and virtual environments
__pycache__/
*.py[cod]
.python-version
.venv/
venv/
env/

# Node dependencies and build outputs
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
coverage/
dist/
build/
.next/
.vite/

# Local environment and generated logs
.env
.env.*
!.env.example
logs/
backend/logs/
test-logs/
runtime/
*.log
*.gz
*.ndjson

# Local credentials and private keys
*.pem
*.key
*.p8
*.p12
*.crt
id_rsa
id_rsa.pub
id_ed25519
id_ed25519.pub
aws_access_key*
aws_secret*
credentials

# Splunk local/runtime artifacts
splunk/*.local
splunk/local/
splunk/var/
splunk/etc/
*.dump

# Editor and local tooling
.idea/
.vscode/
*.swp
*.swo

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
