# Local .terraform directories
**/.terraform/*

# .tfstate files
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files, which are likely to contain sensitive data
*.tfvars
*.tfvars.json

# Ignore override files
*_override.tf
*_override.tf.json

# Ignore CLI configuration files
.terraformrc
terraform.rc

# Ignore tfplan
*tfplan*
*.tfplan

# Python cache and virtual environments
__pycache__/
*.py[cod]
.python-version
.venv/
venv/
env/

# Node dependencies and build outputs
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
coverage/
dist/
build/
.next/
.vite/

# Local environment and generated logs
.env
.env.*
!.env.example
logs/
backend/logs/
test-logs/
*.log
*.gz

# Editor and local tooling
.idea/
.vscode/
*.swp
*.swo

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
