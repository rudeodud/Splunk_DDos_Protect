aws_region   = "ap-northeast-2"
project_name = "splunk-ddos-protect"
environment  = "dev"

vpc_cidr             = "10.0.0.0/16"
availability_zones   = ["ap-northeast-2a", "ap-northeast-2c"]
public_subnet_cidrs  = ["10.0.0.0/24", "10.0.10.0/24"]
private_subnet_cidrs = ["10.0.1.0/24", "10.0.11.0/24"]

key_pair_name = "your-ec2-keypair"
admin_cidr    = "203.0.113.10/32"

bastion_instance_type = "t3.micro"
app_instance_type     = "t3.micro"
splunk_instance_type  = "t3.medium"
app_port              = 3000
app_source_repo       = "https://github.com/rudeodud/Splunk_DDos_Protect.git"
app_source_ref        = "main"

# Splunk Enterprise EC2를 Terraform이 생성합니다. 아래 값을 비우면 자동 생성된 Splunk EC2로 연결됩니다.
splunk_web_port                     = 8000
splunk_hec_port                     = 8088
splunk_admin_password               = ""
splunk_download_url                 = "https://download.splunk.com/products/splunk/releases/9.2.1/linux/splunk-9.2.1-78803f08aabb.x86_64.rpm"
splunk_hec_url                      = ""
splunk_hec_token                    = ""
splunk_hec_token_ssm_parameter_name = ""
splunk_hec_index                    = "main"
splunk_hec_source                   = "virtual-store"
splunk_hec_sourcetype               = "ddos:store:click"
splunk_hec_insecure                 = false

log_bucket_name    = "your-unique-splunk-ddos-logs-bucket"
log_retention_days = 90

waf_rate_limit = 2000
